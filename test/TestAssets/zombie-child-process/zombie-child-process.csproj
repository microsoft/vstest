<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TestProject>true</TestProject>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFrameworks>$(NetCoreAppTargetFrameworks)</TargetFrameworks>
    <RootNamespace>zombie_child_process</RootNamespace>
