<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0</TargetFrameworks>
    <IsFilterSourcePackage>true</IsFilterSourcePackage>
    <DevelopmentDependency>true</DevelopmentDependency>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable Condition="'$(DotNetBuildSourceOnly)' != 'true'">true</IsPackable>
    <NuspecFile>Microsoft.TestPlatform.Filter.Source.nuspec</NuspecFile>
    <NuspecBasePath>$(OutputPath)</NuspecBasePath>
    <PackageId>Microsoft.TestPlatform.Filter.Source</PackageId>
    <PackageTags>vstest visual-studio unittest testplatform mstest microsoft test testing filter</PackageTags>
    <PackageDescription>The Microsoft Test Platform Filter Implementation.</PackageDescription>
  </PropertyGroup>

</Project>
