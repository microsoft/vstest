  <!-- The source-build / non-Windows localized satellite resources are collected with wildcards.
       Item wildcards in a static <ItemGroup> are expanded during evaluation, before the referenced
       projects' resources have been copied into this project's output, so a clean build would match
       nothing. They are instead gathered at pack time: TargetsForTfmSpecificContentInPackage runs in
       the inner (per-TFM) build where $(OutputPath) is already populated. The target is gated to
       $(NetCurrent) so the content is added exactly once.
       Note: in the inner build $(OutputPath) already points at the per-TFM output directory
       (e.g. artifacts\bin\...\Release\net11.0\), so the '$(OutputPath)**' globs only ever span that
       single TFM's sub-folders. %(RecursiveDir) is therefore just the language folder (cs, de, ...),
       not a leading TFM directory, and the package layout stays contentFiles\any\$(NetCurrent)\<lang>\. -->
  <PropertyGroup Condition="'$(DotNetBuildSourceOnly)' == 'true' or '$(OS)' != 'Windows_NT'">
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_IncludeCliSourceBuildResources</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Target Name="_IncludeCliSourceBuildResources"
          Condition="('$(DotNetBuildSourceOnly)' == 'true' or '$(OS)' != 'Windows_NT') and '$(TargetFramework)' == '$(NetCurrent)'"
          Returns="@(TfmSpecificPackageFile)">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(OutputPath)**\Microsoft.TestPlatform.*.resources.dll"
                              Exclude="$(OutputPath)**\*TestHostRuntimeProvider*.resources.dll;$(OutputPath)**\*BlameDataCollector*.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(OutputPath)**\Microsoft.TestPlatform.TestHostRuntimeProvider.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\Extensions\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(OutputPath)**\Microsoft.TestPlatform.Extensions.BlameDataCollector.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\Extensions\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(OutputPath)**\Microsoft.VisualStudio.TestPlatform.*.resources.dll"
                              Exclude="$(OutputPath)**\*Html*.resources.dll;$(OutputPath)**\*Trx*.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(OutputPath)**\Microsoft.VisualStudio.TestPlatform.Extensions.Html.TestLogger.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\Extensions\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(OutputPath)**\Microsoft.VisualStudio.TestPlatform.Extensions.Trx.TestLogger.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\Extensions\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(OutputPath)**\vstest.console.resources.dll">
        <PackagePath>contentFiles\any\$(NetCurrent)\%(RecursiveDir)</PackagePath>
        <BuildAction>None</BuildAction>
        <PackageCopyToOutput>true</PackageCopyToOutput>
        <PackageFlatten>false</PackageFlatten>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>

