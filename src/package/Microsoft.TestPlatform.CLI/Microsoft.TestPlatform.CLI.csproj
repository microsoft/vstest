<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(NetSDKTargetFramework);$(TestHostAllTargetFrameworks)</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <!-- This package is included even in source build -->
    <ExcludeFromSourceOnlyBuild>false</ExcludeFromSourceOnlyBuild>
    <!-- This is a packaging container project: it ships content files only, no assembly of its
         own and no NuGet dependencies. -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Microsoft.TestPlatform.CLI</PackageId>
    <PackageTags>vstest visual-studio unittest testplatform mstest microsoft test testing</PackageTags>
    <PackageProjectUrl>https://github.com/microsoft/vstest</PackageProjectUrl>
    <RepositoryUrl>https://github.com/microsoft/vstest</RepositoryUrl>
    <PackageDescription>
      The cross platform Microsoft Test Platform.
    </PackageDescription>
    <!-- NU5109/NU5118: assemblies/content placed outside lib (intentional, everything ships under contentFiles).
         NU5128: no dependencies and no lib folder. -->
    <NoWarn>$(NoWarn);NU5109;NU5118;NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <None Include="$(SrcPackageFolder)ThirdPartyNotices.txt" Pack="true" PackagePath="" />
  </ItemGroup>

  <!-- Windows (non source-build) ships the full content tree, including the .NET Framework test hosts.
