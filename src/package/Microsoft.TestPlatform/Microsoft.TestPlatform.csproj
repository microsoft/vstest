  <!--
    The two Microsoft.Internal.CodeCoverage content trees were referenced in the old nuspec via
    wildcards against the net48 build output (staged there by the CopyFiles target). With MSBuild
    pack a static wildcard item is expanded at evaluation time, before Build/CopyFiles runs, so the
    files would be missing on a clean build. Instead, add them at pack time from the immutable
    restored package (its path property is only defined in the inner, per-TFM build) and gate to the
    .NET Framework runner TFM so the content is included exactly once.
    Each tree is globbed into its own temporary item so that the PackagePath's %(RecursiveDir) batches
    only over that tree's files; combining two %(RecursiveDir) globs in a single TfmSpecificPackageFile
    ItemGroup would otherwise cross-product every file with every directory.
  -->
  <Target Name="_IncludeInternalCodeCoverageContent" Condition="'$(TargetFramework)' == '$(NetFrameworkRunnerTargetFramework)'" Returns="@(TfmSpecificPackageFile)">
    <ItemGroup>
      <_CodeCoverageTestPlatformContent Include="$(PkgMicrosoft_Internal_CodeCoverage)\contentFiles\MS.TP\TestPlatform\**\*">
        <PackagePath>tools\net462\Common7\IDE\Extensions\TestPlatform\%(RecursiveDir)</PackagePath>
      </_CodeCoverageTestPlatformContent>
      <_CodeCoverageDynamicToolsContent Include="$(PkgMicrosoft_Internal_CodeCoverage)\contentFiles\MS.TP\Dynamic Code Coverage Tools\**\*">
        <PackagePath>tools\net462\Team Tools\Dynamic Code Coverage Tools\%(RecursiveDir)</PackagePath>
      </_CodeCoverageDynamicToolsContent>
      <TfmSpecificPackageFile Include="@(_CodeCoverageTestPlatformContent);@(_CodeCoverageDynamicToolsContent)" />
    </ItemGroup>
  </Target>
</Project>
