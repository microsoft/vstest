<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="12.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_MSTestEnableParentProcessQuery Condition="'$(UseUwpTools)'=='true'">false</_MSTestEnableParentProcessQuery>
    <_MSTestEnableParentProcessQuery Condition="'$(_MSTestEnableParentProcessQuery)'==''">true</_MSTestEnableParentProcessQuery>
  </PropertyGroup>
  <ItemGroup>
    <RuntimeHostConfigurationOption
      Include="MSTest.EnableParentProcessQuery"
      Value="$(_MSTestEnableParentProcessQuery)"
      Trim="true" />
  </ItemGroup>

  <!--
    run-as-exe: only projects that opted into running as their own executable (<OutputType>Exe</OutputType>)
    reference testhost.dll so their generated Main can invoke the testhost engine, and get the testhost engine
    closure copied next to their output so the exe can host the tests. Normal (Library) test projects do NOT
    reference or copy any of this, so their output stays identical to before. This payload ships under
    build\net462\runAsExe\ (NOT lib\) so it is never auto-referenced.
  -->
  <ItemGroup Condition="'$(OutputType)' == 'Exe'">
    <Reference Include="testhost">
      <HintPath>$(MSBuildThisFileDirectory)runAsExe\testhost.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Content Include="$(MSBuildThisFileDirectory)runAsExe\**\*.dll" Exclude="$(MSBuildThisFileDirectory)runAsExe\testhost.dll">
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
  </ItemGroup>

  <!--
    run-as-exe: copy the built-in testhost*.exe launchers next to the test output ONLY for normal (Library)
    .NET Framework test projects. Projects that opted into run-as-exe (<OutputType>Exe</OutputType>) run as
    their own executable and must NOT get testhost*.exe in their output. Imported as a target (not props) so
    that $(OutputType) is already set when the condition is evaluated.
  -->
  <!-- x86: when Platform OR PlatformTarget is x86 -->
  <!-- this depends on whether we want to support switching architectures and tfms for netframework that uses testhost in bin folder -->
  <!--<ItemGroup Condition=" ( '$(Platform)' == 'x86' OR '$(PlatformTarget)' == 'x86' ) AND '$(OS)' == 'Windows_NT' ">-->
  <ItemGroup Condition=" '$(OutputType)' != 'Exe' AND '$(OS)' == 'Windows_NT' ">
    <!-- Base -->
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.x86.exe">
      <Link>testhost.x86.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.x86.exe.config">
      <Link>testhost.x86.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.7 -->
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net47.x86.exe">
      <Link>testhost.net47.x86.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net47.x86.exe.config">
      <Link>testhost.net47.x86.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.7.1 -->
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net471.x86.exe">
      <Link>testhost.net471.x86.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net471.x86.exe.config">
      <Link>testhost.net471.x86.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.7.2 -->
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net472.x86.exe">
      <Link>testhost.net472.x86.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net472.x86.exe.config">
      <Link>testhost.net472.x86.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.8 -->
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net48.x86.exe">
      <Link>testhost.net48.x86.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net48.x86.exe.config">
      <Link>testhost.net48.x86.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.8.1 -->
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net481.x86.exe">
      <Link>testhost.net481.x86.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x86\testhost.net481.x86.exe.config">
      <Link>testhost.net481.x86.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
  </ItemGroup>

 

  <!-- x64 / non-x86, non-ARM64: default bucket -->
  <!--<ItemGroup Condition=" ( '$(Platform)' != 'x86' AND '$(PlatformTarget)' != 'x86' AND '$(Platform)' != 'arm64' AND '$(PlatformTarget)' != 'arm64' ) AND '$(OS)' == 'Windows_NT' ">-->
    <ItemGroup Condition=" '$(OutputType)' != 'Exe' AND '$(OS)' == 'Windows_NT' ">
    <!-- Base -->
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.exe">
      <Link>testhost.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.exe.config">
      <Link>testhost.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.7 -->
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net47.exe">
      <Link>testhost.net47.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net47.exe.config">
      <Link>testhost.net47.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.7.1 -->
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net471.exe">
      <Link>testhost.net471.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net471.exe.config">
      <Link>testhost.net471.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.7.2 -->
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net472.exe">
      <Link>testhost.net472.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net472.exe.config">
      <Link>testhost.net472.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.8 -->
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net48.exe">
      <Link>testhost.net48.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net48.exe.config">
      <Link>testhost.net48.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>

    <!-- .NET 4.8.1 -->
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net481.exe">
      <Link>testhost.net481.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)x64\testhost.net481.exe.config">
      <Link>testhost.net481.exe.config</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
  </ItemGroup>
</Project>

