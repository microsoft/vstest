<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(TestHostMinimumTargetFrameworks)</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Don't pack on non-Windows as it doesn't build correctly. -->
    <IsPackable Condition="'$(OS)' == 'Windows_NT'">true</IsPackable>
    <PackageId>Microsoft.TestPlatform.TestHost</PackageId>
    <PackageTags>vstest visual-studio unittest testplatform mstest microsoft test testing</PackageTags>
    <PackageDescription>
      Testplatform host executes the test using specified adapter.
    </PackageDescription>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- This package bundles the testhost runtime output rather than shipping its own assembly. -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <!-- MSB3270 Suppress warnings about platform specific projects imported in AnyCPU (MSIL) projects. -->
    <ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>None</ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>
    <!-- NU5128: net462 ships an empty dependency group; NU5100: bundled assemblies live under lib\ and
         build\ rather than being the project's own build output. -->
    <NoWarn>$(NoWarn);NU5128;NU5100</NoWarn>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);IncludeTestHostContent;IncludeRunAsExeContent</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)src\testhost\testhost.csproj" PrivateAssets="all" />
    <ProjectReference Include="$(RepoRoot)src\testhost.x86\testhost.x86.csproj" PrivateAssets="all" />
    <!-- ObjectModel ships as its own package, so it is a real dependency. net8.0 needs it for the bundled
         runtime; net462 needs it so run-as-exe test projects can reference the [RunAsExe] attribute (which lives
         in ObjectModel) at compile time, and so NuGet unifies ObjectModel to this version. -->
    <ProjectReference Include="$(RepoRoot)src\Microsoft.TestPlatform.ObjectModel\Microsoft.TestPlatform.ObjectModel.csproj" />
    <!-- run-as-exe: a referenceable .NET Framework testhost.dll (OutputType=Library, AssemblyName=testhost),
         bundled privately so net462 test projects built as exe can reference the testhost entry point. It is
         dropped from the package dependency list by RemoveTestHostProjectDependencies below. -->
    <ProjectReference Include="$(RepoRoot)src\testhost.library\testhost.library.csproj"
                      Condition=" '$(TargetFramework)' == 'net462' " PrivateAssets="all" />
  </ItemGroup>

  <!-- The testhost executables are bundled as content, not consumed as packages, so they must not
       appear as NuGet dependencies. PrivateAssets is not honored for these exe project references, so
       drop them from the resolved dependency list before the nuspec is generated. -->
  <Target Name="RemoveTestHostProjectDependencies" BeforeTargets="GenerateNuspec">
    <ItemGroup>
      <_ProjectReferencesWithVersions Remove="@(_ProjectReferencesWithVersions)"
                                      Condition=" '%(Filename)' == 'testhost' or '%(Filename)' == 'testhost.x86' or '%(Filename)' == 'testhost.library' " />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <PackageReference Include="Microsoft.Internal.Dia" Version="$(TestPlatformMSDiaVersion)" PrivateAssets="All" GeneratePathProperty="true" />
  </ItemGroup>

  <Target Name="CopyDiaFiles" AfterTargets="Build">
    <ItemGroup>
      <DiaFilesX86 Include="$(PkgMicrosoft_Internal_Dia)\tools\net451\x86\*"></DiaFilesX86>
      <DiaFilesX64 Include="$(PkgMicrosoft_Internal_Dia)\tools\net451\x64\*"></DiaFilesX64>
      <DiaFilesArm64 Include="$(PkgMicrosoft_Internal_Dia)\tools\net451\arm64\*"></DiaFilesArm64>
    </ItemGroup>
    <Copy SourceFiles="@(DiaFilesX86)" DestinationFolder="$(OutDir)\x86" />
    <Copy SourceFiles="@(DiaFilesX64)" DestinationFolder="$(OutDir)\x64" />
    <Copy SourceFiles="@(DiaFilesArm64)" DestinationFolder="$(OutDir)\arm64" />
  </Target>

  <ItemGroup>
    <None Update="_._">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Microsoft.TestPlatform.TestHost.props" Condition=" $([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', '$(NetCoreAppMinimum)')) ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Microsoft.TestPlatform.TestHost.targets" Condition=" $([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', '$(NetCoreAppMinimum)')) ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Package contents that are independent of the build framework. -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <None Include="$(SrcPackageFolder)ThirdPartyNotices.txt" Pack="true" PackagePath="" />
    <!-- .NET Framework consumers get the testhost shipped with vstest.console, so only a stub is needed. -->
    <None Include="_._" Pack="true" PackagePath="lib\net462\" />
    <!-- run-as-exe: net462 build integration (Exe-conditional testhost reference + closure copy). -->
    <None Include="build\net462\Microsoft.TestPlatform.TestHost.props" Pack="true" PackagePath="build\net462\" />
    <None Include="build\net462\Microsoft.TestPlatform.TestHost.targets" Pack="true" PackagePath="build\net462\" />
  </ItemGroup>

  <!-- Bundle the .NET testhost runtime output: the platform assemblies and satellites in lib\net8.0,
       the msdia natives, the testhost launchers under build\net8.0 and the MSBuild props/targets.
       Runs in the inner net8.0 build (where the output and Dia path property are available). -->
  <Target Name="IncludeTestHostContent"
          Condition=" $([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', '$(NetCoreAppMinimum)')) "
          Returns="@(TfmSpecificPackageFile)">
    <ItemGroup>
      <!-- Platform assemblies (everything except this package's own TestHost assembly). -->
      <TfmSpecificPackageFile Include="$(OutputPath)Microsoft.VisualStudio.TestPlatform.*.dll" PackagePath="lib/$(TargetFramework)/" />
      <TfmSpecificPackageFile Include="$(OutputPath)Microsoft.TestPlatform.*.dll"
                              Exclude="$(OutputPath)Microsoft.TestPlatform.TestHost.dll"
                              PackagePath="lib/$(TargetFramework)/" />
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.dll" PackagePath="lib/$(TargetFramework)/" />
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.deps.json" PackagePath="lib/$(TargetFramework)/" />

      <!-- msdia natives. -->
      <TfmSpecificPackageFile Include="$(OutputPath)x86\msdia140.dll" PackagePath="lib/$(TargetFramework)/x86/" />
      <TfmSpecificPackageFile Include="$(OutputPath)x64\msdia140.dll" PackagePath="lib/$(TargetFramework)/x64/" />
      <TfmSpecificPackageFile Include="$(OutputPath)arm64\msdia140.dll" PackagePath="lib/$(TargetFramework)/arm64/" />

      <!-- testhost launchers (see the original nuspec for why the AnyCPU testhost.dll is used for x64). -->
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.dll" PackagePath="build/$(TargetFramework)/x64/" />
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.exe" PackagePath="build/$(TargetFramework)/x64/" />
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.x86.dll" PackagePath="build/$(TargetFramework)/x86/" />
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.x86.exe" PackagePath="build/$(TargetFramework)/x86/" />

      <!-- MSBuild integration. -->
      <TfmSpecificPackageFile Include="$(OutputPath)Microsoft.TestPlatform.TestHost.props" PackagePath="build/$(TargetFramework)/" />
      <TfmSpecificPackageFile Include="$(OutputPath)Microsoft.TestPlatform.TestHost.targets" PackagePath="build/$(TargetFramework)/" />

      <!-- Satellite resources for the bundled assemblies (CommunicationUtilities, CrossPlatEngine, Common). -->
      <TfmSpecificPackageFile Include="$(OutputPath)**/Microsoft.TestPlatform.CommunicationUtilities.resources.dll" PackagePath="lib/$(TargetFramework)/" />
      <TfmSpecificPackageFile Include="$(OutputPath)**/Microsoft.TestPlatform.CrossPlatEngine.resources.dll" PackagePath="lib/$(TargetFramework)/" />
      <TfmSpecificPackageFile Include="$(OutputPath)**/Microsoft.VisualStudio.TestPlatform.Common.resources.dll" PackagePath="lib/$(TargetFramework)/" />
    </ItemGroup>
  </Target>

  <!-- run-as-exe: .NET Framework testhost closure, shipped under build\net462\runAsExe\ (NOT lib\, so it is
       never auto-referenced). The build\net462 targets reference testhost.dll and copy this closure next to the
       test output only for projects that opted into OutputType=Exe. Runs in the net462 inner build. -->
  <Target Name="IncludeRunAsExeContent"
          Condition=" '$(TargetFramework)' == 'net462' "
          Returns="@(TfmSpecificPackageFile)">
    <ItemGroup>
      <!-- Platform assemblies (everything except this package's own TestHost assembly). -->
      <TfmSpecificPackageFile Include="$(OutputPath)Microsoft.VisualStudio.TestPlatform.*.dll" PackagePath="build/net462/runAsExe/" />
      <TfmSpecificPackageFile Include="$(OutputPath)Microsoft.TestPlatform.*.dll"
                              Exclude="$(OutputPath)Microsoft.TestPlatform.TestHost.dll"
                              PackagePath="build/net462/runAsExe/" />
      <!-- The referenceable testhost.dll (from testhost.library). -->
      <TfmSpecificPackageFile Include="$(OutputPath)testhost.dll" PackagePath="build/net462/runAsExe/" />
      <!-- msdia natives. -->
      <TfmSpecificPackageFile Include="$(OutputPath)x86\msdia140.dll" PackagePath="build/net462/runAsExe/x86/" />
      <TfmSpecificPackageFile Include="$(OutputPath)x64\msdia140.dll" PackagePath="build/net462/runAsExe/x64/" />
      <!-- Satellite resources for the bundled assemblies. -->
      <TfmSpecificPackageFile Include="$(OutputPath)**/Microsoft.TestPlatform.CommunicationUtilities.resources.dll" PackagePath="build/net462/runAsExe/" />
      <TfmSpecificPackageFile Include="$(OutputPath)**/Microsoft.TestPlatform.CrossPlatEngine.resources.dll" PackagePath="build/net462/runAsExe/" />
      <TfmSpecificPackageFile Include="$(OutputPath)**/Microsoft.VisualStudio.TestPlatform.Common.resources.dll" PackagePath="build/net462/runAsExe/" />
    </ItemGroup>
  </Target>
</Project>
